{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "rseq",
  "scopeName": "source.rseq",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#macros" },
    { "include": "#keywords" },
    { "include": "#report-kinds" },
    { "include": "#report-options" },
    { "include": "#buses" },
    { "include": "#registers" },
    { "include": "#identifiers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rseq",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.rseq",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.rseq",
          "match": "\\\\([ntr\"\\\\]|x[0-9a-fA-F]{2})"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.rseq",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.decimal.rseq",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.rseq",
          "match": "\\b(chip|bus|bus_probe|read|write|update|irq|repeat|print|report_format|report|wait)!"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rseq",
          "match": "\\b(if|else|on|let)\\b"
        }
      ]
    },
    "report-kinds": {
      "patterns": [
        {
          "name": "constant.language.report-kind.rseq",
          "match": "\\b(FIFO_RAW|AMD|SMD|DRDY)\\b"
        }
      ]
    },
    "report-options": {
      "patterns": [
        {
          "name": "support.type.report-decoder.rseq",
          "match": "\\b(i16_le|qmi8660_fifo6|physical_f32|raw_i16)\\b"
        },
        {
          "name": "support.type.property-name.rseq",
          "match": "\\b(fields|gyro_fields|accel_fields|temp_field|accel_fs_g|gyro_fs_dps|temp_lsb_per_c|temp_offset_c|output)\\b(?=\\s*:)"
        }
      ]
    },
    "buses": {
      "patterns": [
        {
          "name": "constant.language.bus.rseq",
          "match": "\\b(spi|i2c|i3c)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "support.constant.register.qualified.rseq",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rseq",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.rseq",
          "match": "(==|!=|<=|>=|<<|>>|&&|\\|\\||[+\\-*/%&|^!<>]=?)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.rseq",
          "match": "[(){}\\[\\]]"
        },
        {
          "name": "punctuation.separator.rseq",
          "match": "[,;:]"
        }
      ]
    }
  }
}

 *
 * rseq MCU common overlay.
 *
 * Board-specific wiring lives in boards/<board>.overlay. Chip bus/address
 * selection is supplied by the rseq script, so this file stays transport-only.
 */

/* USB CDC-ACM — the rseq-link transport channel. */
&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};
